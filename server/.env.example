# ── 서버 전용 환경변수 ──────────────────────────────────────
# 이 파일을 복사하여 server/.env 로 저장 후 값을 채워주세요.
# server/.env 는 절대 커밋하지 마세요 (API 키 포함).

# Anthropic Claude API 키 (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=your_api_key_here

# 서버 포트 (기본값: 3000)
PORT=3000

# SQLite DB 파일 경로 (server/ 폴더 기준 상대경로)
DB_PATH=./database.sqlite
